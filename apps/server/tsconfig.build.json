{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.cache/tsconfig.build.tsbuildinfo",
    "noEmit": false,
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@webcli/contracts": ["../../packages/contracts/dist/index.d.ts"],
      "@webcli/core": ["../../packages/core/dist/index.d.ts"],
      "@webcli/runtime-codex": ["../../packages/runtime-codex/dist/index.d.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "references": [
    { "path": "../../packages/contracts/tsconfig.build.json" },
    { "path": "../../packages/core/tsconfig.build.json" },
    { "path": "../../packages/runtime-codex/tsconfig.build.json" }
  ]
}
