{
  "name": "webcli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=25 <26"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build:workspaces": "npm run build --workspaces --if-present",
    "dev": "npm run build -w @webcli/contracts && npm run build -w @webcli/core && npm run build -w @webcli/runtime-codex && concurrently -k -n server,web -c cyan,magenta \"npm run dev -w @webcli/server\" \"npm run dev -w @webcli/web\"",
    "build": "npm run build:workspaces",
    "deploy:staging": "bash ./deploy/staging/bin/deploy.sh",
    "deploy:staging:rollback": "bash ./deploy/staging/bin/rollback.sh",
    "test:repo": "node --test ./scripts/task-workflow.test.mjs ./scripts/parity-matrix.test.mjs",
    "test:workspaces": "npm run test --workspaces --if-present",
    "test": "npm run test:repo && npm run test:workspaces",
    "typecheck:workspaces": "npm run typecheck --workspaces --if-present",
    "typecheck": "npm run typecheck:workspaces",
    "e2e": "playwright test",
    "verify": "npm run build && npm run typecheck && npm run test && npm run e2e",
    "task:start": "node ./scripts/task-workflow.mjs start",
    "task:sync": "node ./scripts/task-workflow.mjs sync",
    "task:finish": "node ./scripts/task-workflow.mjs finish"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.0.0",
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3"
  }
}
