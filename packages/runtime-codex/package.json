{
  "name": "@webcli/runtime-codex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "regen": "codex app-server generate-ts --out src/generated"
  },
  "dependencies": {
    "@webcli/contracts": "file:../contracts",
    "@webcli/core": "file:../core"
  }
}
